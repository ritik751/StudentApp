<Window x:Class="StudentApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudentApp.ViewModels"
        xmlns:conv="clr-namespace:StudentApp.Converters"
        Title="Students" Height="450" Width="900">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:StreamToBrushConverter x:Key="StreamColor"/>
    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Add Button -->
        <StackPanel Orientation="Horizontal" Margin="10">

            <Button Content="Add Student"
                    Width="120"
                    Height="35"
                    Command="{Binding AddStudentCommand}"/>

        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Students}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTemplateColumn Header="Image">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Image}" Width="40"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>

                <DataGridTextColumn Header="Age" Binding="{Binding Age}"/>

                <DataGridTemplateColumn Header="Stream">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Stream}"
                                       Background="{Binding Stream,Converter={StaticResource StreamColor}}"
                                       Padding="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Date Of Joining"
                                    Binding="{Binding DateOfJoining,StringFormat='{}{0:dd MMM yyyy}'}"/>

                <DataGridTextColumn Header="Due Fee"
                                    Binding="{Binding DueFee,StringFormat='{}{0} Rs'}"/>

                <DataGridTextColumn Header="Total Fee"
                                    Binding="{Binding TotalFee,StringFormat='{}{0} Rs'}"/>

                <DataGridTemplateColumn Header="Edit">

                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <Button Command="{Binding DataContext.EditCommand,
RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent">

                                <TextBlock Text="✎" FontSize="16"/>

                            </Button>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>