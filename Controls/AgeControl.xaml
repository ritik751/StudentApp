<UserControl x:Class="StudentApp.Controls.AgeControl"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Orientation="Horizontal">

        <Button Content="-" Click="Decrease_Click" Width="30"/>

        <TextBox Width="60"
              Text="{Binding Age,RelativeSource={RelativeSource AncestorType=UserControl},
              Mode=TwoWay}" HorizontalContentAlignment="Center"/>

        <Button Content="+" Click="Increase_Click" Width="30"/>

    </StackPanel>

</UserControl>